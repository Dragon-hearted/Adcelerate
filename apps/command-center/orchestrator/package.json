{
  "name": "@command-center/orchestrator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "module": "src/server.ts",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "CC_DB_PATH=:memory: bun test",
    "drizzle:generate": "drizzle-kit generate",
    "migrate": "bun src/db/migrate.ts",
    "import-legacy": "bun src/db/import-legacy.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.168",
    "@command-center/shared": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "chokidar": "^5.0.0",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.8.5",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.1",
    "socket.io-client": "^4.8.3",
    "typescript": "^5.8.3"
  }
}

# Claude Command Center — app-local recipes.
# Proxied from the repo-root justfile `cc-*` recipes (added in Phase 8).
# `set positional-arguments` mirrors the root justfile convention.
set positional-arguments

# Default: list recipes.
default:
    @just --list

# Install all workspace dependencies (web, orchestrator, shared).
install:
    bun install

# Typecheck every workspace package (tsc --noEmit).
typecheck:
    bun run --filter '*' typecheck

# Generate Drizzle migrations from the schema.
migrate-generate:
    bun run --filter @command-center/orchestrator drizzle:generate

# Apply Drizzle migrations to the SQLite database.
migrate:
    bun run --filter @command-center/orchestrator migrate

# Apply migrations AND import the legacy apps/server/events.db (idempotent).
# Pass an optional legacy DB path: `just migrate-import /path/to/events.db`.
migrate-import *args:
    bun run --filter @command-center/orchestrator migrate
    bun run --filter @command-center/orchestrator import-legacy "$@"

# Run the orchestrator (Fastify + Socket.IO @ :4100) in watch mode.
dev-orchestrator:
    bun run --filter @command-center/orchestrator dev

# Run the Next.js web app (@ :3000) in dev mode.
dev-web:
    bun run --filter web dev

# Bring up orchestrator (:4100) + web (:3000) concurrently. Ctrl-C stops both.
dev:
    #!/usr/bin/env sh
    set -eu
    bun run --filter @command-center/orchestrator dev &
    orch=$!
    bun run --filter web dev &
    web=$!
    # Propagate Ctrl-C / TERM to both children, then reap.
    trap 'kill "$orch" "$web" 2>/dev/null || true' INT TERM EXIT
    wait "$orch" "$web"

# Production build (web).
build:
    bun run --filter web build

# Run unit tests.
test:
    bun test

# Verify the copied Emitter (ADR-0008) is byte-identical across submodules.
# sha256 the canonical source in shared vs each submodule copy; exit non-zero on
# drift (ADR-0020 — copies that fall out of sync are a contract break).
emitter-checksum:
    #!/usr/bin/env sh
    set -eu
    canonical="packages/shared/emitter.ts"
    # Space-separated list of submodule copies to check (only image-engine today).
    copies="../../systems/image-engine/src/lib/emitter.ts"
    want=$(shasum -a 256 "$canonical" | cut -d' ' -f1)
    printf 'canonical %s\n  sha256 %s\n' "$canonical" "$want"
    drift=0
    for copy in $copies; do
        got=$(shasum -a 256 "$copy" | cut -d' ' -f1)
        if [ "$got" = "$want" ]; then
            printf '  [in-sync] %s\n' "$copy"
        else
            printf '  [DRIFT]   %s\n           sha256 %s\n' "$copy" "$got"
            drift=1
        fi
    done
    if [ "$drift" -ne 0 ]; then
        echo "Emitter drift detected — re-copy the canonical source into the submodule." >&2
        exit 1
    fi
    echo "all Emitter copies in sync"

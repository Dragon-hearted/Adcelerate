# pdf-kit
set dotenv-load := true

# List all recipes
default:
  @just --list

# Run render in watch mode
dev:
  bun run dev

# Build CLI to dist/
build:
  bun run build

# Type-check without emitting
typecheck:
  bun run typecheck

# Render a TSX doc to PDF
# Usage: just render src/demo/system-doc.tsx out/sample.pdf
render input output:
  bun run pdf:render {{input}} {{output}}

# Render the demo doc
demo:
  bun run pdf:render src/demo/system-doc.tsx out/sample.pdf

# Lint code
lint:
  bun run lint

# Check and fix formatting
check:
  bun run check

{
  "name": "@adcelerate/gif-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Branded GIF rendering via Remotion — composable motion assets for Adcelerate brand",
  "_peerDepsNote": "remotion + react + react-dom must be version-aligned; Remotion requires a single copy resolved per project",
  "scripts": {
    "dev": "bunx remotion studio src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "gif:render": "bun run src/render.ts"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.451",
    "@remotion/cli": "^4.0.451",
    "@remotion/renderer": "^4.0.451",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remotion": "^4.0.451"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
